<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF"/>
        </shape>
    </item>

    <item android:top="0dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#22000000"
                android:endColor="#00000000"
                android:angle="90"/>
        </shape>
    </item>

</layer-list>