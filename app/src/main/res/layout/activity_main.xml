<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#C8E6C9"
    android:orientation="vertical"
    tools:context=".MainActivity">

    <View
        android:id="@+id/view2"
        android:layout_width="wrap_content"
        android:layout_height="1dp" />

    <FrameLayout
        android:id="@+id/toolbar"
        android:layout_width="wrap_content"
        android:layout_height="100dp"
        android:minHeight="?attr/actionBarSize"
        android:theme="?attr/actionBarTheme">

        <ImageView
            android:id="@+id/imageView3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:scaleType="centerCrop"
            app:srcCompat="@drawable/medicine" />

        <TextView
            android:id="@+id/textView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="약 알리미"
            android:textColor="#3F51B5"
            android:textSize="30sp"
            android:textStyle="bold" />

    </FrameLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/timeMedicine"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:layout_below="@id/toolbar"
        android:overScrollMode="always"
        android:scrollIndicators="bottom"
        tools:listitem="@layout/item" >

    </androidx.recyclerview.widget.RecyclerView>

    <View
        android:id="@+id/view"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_above="@id/bottom_bar"
        android:background="#cccccc"
        />

    <RelativeLayout
        android:id="@+id/bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="2dp"
        android:background="#C8E6C9"
        android:backgroundTint="@color/cardview_shadow_end_color">

        <Button
            android:id="@+id/home"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:backgroundTint="#C8E6C9"
            android:isScrollContainer="true"
            android:onClick="onClick"
            android:text="home"
            android:textStyle="bold"
            app:icon="@drawable/KakaoTalk_20260526_200624212_07" />

        <Button
            android:id="@+id/setting"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_alignParentEnd="true"
            android:layout_toStartOf="@id/fab"
            android:backgroundTint="#C8E6C9"
            android:onClick="onClick"
            android:text="setting"
            android:textStyle="bold"
            app:icon="@drawable/KakaoTalk_20260526_200624212_02"
            app:iconTint="#A9A0A0" />

        <Button
            android:id="@+id/statics"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_alignParentEnd="false"
            android:layout_toEndOf="@id/fab"
            android:backgroundTint="#C8E6C9"
            android:text="통계" />

        <View
            android:id="@+id/fab"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_centerInParent="true"
            android:layout_marginBottom="10dp"
            android:background="#E0D0FF"
            android:contentDescription="약 추가하기 버튼"
            android:onClick="onClick" />

        <Button
            android:id="@+id/logout2"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_alignParentStart="false"
            android:layout_toStartOf="@id/fab"
            android:layout_toEndOf="@id/home"
            android:backgroundTint="#C8E6C9"
            android:onClick="onClick"
            android:text="logout"
            android:textStyle="bold" />
    </RelativeLayout>

</RelativeLayout>